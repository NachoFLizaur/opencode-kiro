{
  "name": "opencode-kiro",
  "version": "0.1.0",
  "description": "Kiro (Amazon Q via ACP) provider plugin for opencode — auth, models, and TUI credits",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./server": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
    "./tui": { "types": "./dist/tui.d.ts", "default": "./dist/tui.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "engines": { "opencode": ">=1.16.0" },
  "peerDependencies": { "@opencode-ai/plugin": "*" },
  "dependencies": { "kiro-acp-ai-provider": "file:../kiro-acp-ai-provider" },
  "devDependencies": {
    "@opencode-ai/plugin": "1.16.2",
    "bun-types": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["opencode", "opencode-plugin", "kiro", "acp", "amazon-q", "aws"]
}
